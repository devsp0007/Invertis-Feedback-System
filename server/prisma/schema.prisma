generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  supreme
  super_admin
  coordinator
  hod
  student
}

enum Status {
  pending
  active
  inactive
  archived
  graduated
  alumni
}

enum TeacherType {
  college_faculty
  trainer
}

// ── Models ───────────────────────────────────────────────────────────────────

model AcademicSession {
  id             String         @id @default(uuid())
  name           String         @unique
  start_year     Int
  end_year       Int
  is_active      Boolean        @default(false)
  users          User[]
  promotionsFrom PromotionLog[] @relation("FromSession")
  promotionsTo   PromotionLog[] @relation("ToSession")

  @@index([is_active])
}

model Department {
  id           String         @id @default(uuid())
  name         String         @unique
  code         String         @unique
  portal_open  Boolean        @default(true)
  max_semester Int            @default(8)
  sections     Section[]
  users        User[]
  courses      Course[]
  faculties    Faculty[]
  promotionLogs PromotionLog[]
}

model Section {
  id             String           @id @default(uuid())
  name           String
  code           String           @unique
  semester       Int
  label          String
  department_id  String
  enrollments    Enrollment[]
  department     Department       @relation(fields: [department_id], references: [id])
  sectionFaculty SectionFaculty[]
  tlfqs          Tlfq[]
  users          User[]

  @@index([department_id])
}

model User {
  id                    String           @id @default(uuid())
  name                  String
  email                 String?          @unique
  password              String?
  role                  Role
  status                Status           @default(active)
  department_id         String?
  section_id            String?
  student_id            String?          @unique
  unique_feedback_id    String?          @unique
  points                Int              @default(0)
  batch                 String?
  semester              Int?
  academic_session_id   String?
  last_promotion_log_id String?
  enrollments           Enrollment[]
  responses             Response[]
  tlfqsCreated          Tlfq[]           @relation("TlfqCreator")
  department            Department?      @relation(fields: [department_id], references: [id])
  section               Section?         @relation(fields: [section_id], references: [id])
  academic_session      AcademicSession? @relation(fields: [academic_session_id], references: [id])
  promotedLogs          PromotionLog[]   @relation("PromotionActor")

  @@index([role])
  @@index([status])
  @@index([department_id])
  @@index([section_id])
  @@index([academic_session_id])
  @@index([points])
}

model PromotionLog {
  id              String          @id @default(uuid())
  admin           User            @relation("PromotionActor", fields: [admin_id], references: [id])
  admin_id        String
  department      Department?     @relation(fields: [department_id], references: [id])
  department_id   String?
  from_session    AcademicSession @relation("FromSession", fields: [from_session_id], references: [id])
  from_session_id String
  to_session      AcademicSession @relation("ToSession", fields: [to_session_id], references: [id])
  to_session_id   String
  scope           String
  semesters       String?
  promoted_count  Int             @default(0)
  graduated_count Int             @default(0)
  skipped_count   Int             @default(0)
  metadata        Json?
  promoted_at     DateTime        @default(now())

  @@index([admin_id])
  @@index([department_id])
  @@index([from_session_id])
  @@index([to_session_id])
  @@index([promoted_at])
}

model Course {
  id             String           @id @default(uuid())
  name           String
  code           String           @unique
  department_id  String
  department     Department       @relation(fields: [department_id], references: [id])
  enrollments    Enrollment[]
  sectionFaculty SectionFaculty[]
  tlfqs          Tlfq[]

  @@index([department_id])
}

model Faculty {
  id             String           @id @default(uuid())
  name           String
  department_id  String
  teacher_type   TeacherType      @default(college_faculty)
  department     Department       @relation(fields: [department_id], references: [id])
  sectionFaculty SectionFaculty[]
  tlfqs          Tlfq[]

  @@index([department_id])
}

model SectionFaculty {
  id         String  @id @default(uuid())
  section_id String
  faculty_id String
  course_id  String
  course     Course  @relation(fields: [course_id], references: [id])
  faculty    Faculty @relation(fields: [faculty_id], references: [id])
  section    Section @relation(fields: [section_id], references: [id])

  @@index([section_id])
  @@index([faculty_id])
  @@index([course_id])
}

model Enrollment {
  id         String  @id @default(uuid())
  student_id String
  course_id  String
  section_id String
  course     Course  @relation(fields: [course_id], references: [id])
  section    Section @relation(fields: [section_id], references: [id])
  student    User    @relation(fields: [student_id], references: [id])

  @@index([student_id])
  @@index([course_id])
  @@index([section_id])
}

model Tlfq {
  id           String     @id @default(uuid())
  section_id   String
  course_id    String
  faculty_id   String
  title        String
  is_active    Boolean    @default(false)
  closing_time DateTime
  created_by   String
  questions    Question[]
  responses    Response[]
  course       Course     @relation(fields: [course_id], references: [id])
  creator      User       @relation("TlfqCreator", fields: [created_by], references: [id])
  faculty      Faculty    @relation(fields: [faculty_id], references: [id])
  section      Section    @relation(fields: [section_id], references: [id])

  @@index([section_id])
  @@index([course_id])
  @@index([faculty_id])
  @@index([is_active])
  @@index([closing_time])
}

model Question {
  id            String   @id @default(uuid())
  tlfq_id       String
  question_text String
  answers       Answer[]
  tlfq          Tlfq     @relation(fields: [tlfq_id], references: [id])

  @@index([tlfq_id])
}

model Response {
  id           String   @id @default(uuid())
  student_id   String
  tlfq_id      String
  submitted_at String
  comment      String?  @default("")
  answers      Answer[]
  student      User     @relation(fields: [student_id], references: [id])
  tlfq         Tlfq     @relation(fields: [tlfq_id], references: [id])

  @@index([student_id])
  @@index([tlfq_id])
}

model Answer {
  id          String   @id @default(uuid())
  response_id String
  question_id String
  rating      Int
  question    Question @relation(fields: [question_id], references: [id])
  response    Response @relation(fields: [response_id], references: [id])

  @@index([response_id])
  @@index([question_id])
}
