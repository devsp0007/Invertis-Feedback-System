# Server Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file

# MongoDB Connection String
# Get this from: https://cloud.mongodb.com → Your Cluster → Connect → Drivers
MONGO_URI=mongodb+srv://<USERNAME>:<PASSWORD>@<CLUSTER>.mongodb.net/<DB_NAME>?retryWrites=true&w=majority

# JWT Secret Key — use a long random string (min 32 characters)
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here

# Server Port
PORT=5000

# Environment
NODE_ENV=production

# Frontend URL (for CORS whitelist — set this to your Vercel deployment URL)
# e.g. https://invertis-feedback.vercel.app
FRONTEND_URL=https://your-vercel-app.vercel.app
